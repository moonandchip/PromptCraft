# =============================================================================
# Rendered by Terraform. Lives at /etc/promptcraft/.env (mode 0600).
# Read by every container via env_file in docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (single database 'promptcraft', two schemas: public + auth)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${db_password}
POSTGRES_DB=promptcraft

# -----------------------------------------------------------------------------
# Backend (FastAPI)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://postgres:${db_password}@db:5432/promptcraft?schema=public
AUTH_SERVICE_URL=http://auth:3000
LEONARDO_API_KEY=${leonardo_api_key}
OPENAI_API_KEY=${openai_api_key}
PROMPT_FEEDBACK_MODEL=${prompt_feedback_model}
CORS_ALLOWED_ORIGINS=${cors_allowed_origins}
CORS_ALLOWED_ORIGIN_REGEX=${cors_allowed_origin_regex}
# Skip CLIP eager warmup; load on first scoring request to keep idle RAM low.
CLIP_SKIP_WARMUP=1

# -----------------------------------------------------------------------------
# Auth service (Next.js + next-auth + Prisma)
# -----------------------------------------------------------------------------
AUTH_DATABASE_URL=postgresql://postgres:${db_password}@db:5432/promptcraft?schema=auth
AUTH_SECRET=${auth_secret}
AUTH_URL=${auth_url}
AUTH_TRUST_HOST=true
NODE_ENV=production
# Used to build password-reset links the auth service logs/emails to users.
APP_ORIGIN=${app_origin}
# Gmail SMTP for password-reset emails. Empty values disable outbound mail
# (the reset link is logged to stdout instead). GMAIL_APP_PASSWORD is a
# 16-char Google App Password from https://myaccount.google.com/apppasswords
# — regular Gmail passwords are rejected by SMTP.
GMAIL_USER=${gmail_user}
GMAIL_APP_PASSWORD=${gmail_app_password}
EMAIL_FROM=${email_from}
