AUTH_DATABASE_URL=postgresql://postgres:postgres@db:5432/promptcraft?schema=auth
AUTH_SECRET=replace-with-long-random-string
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Used to build password-reset links logged/emailed to users
APP_ORIGIN=http://localhost:5173

# Gmail SMTP for password-reset emails. GMAIL_APP_PASSWORD must be a 16-char
# App Password generated at https://myaccount.google.com/apppasswords
# (regular Gmail passwords are rejected by SMTP). 2FA must be enabled on
# the account first. Leave both empty to fall back to logging the reset
# link to stdout instead of sending mail.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional. Defaults to "PromptCraft <${GMAIL_USER}>".
EMAIL_FROM=PromptCraft <noreply@promptcrafts.net>
