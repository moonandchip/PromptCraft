# Database
# Auto-normalized: postgres:// → postgresql+psycopg://
DATABASE_URL=postgresql://postgres:postgres@db:5432/promptcraft?schema=public

# External services
LEONARDO_API_KEY=your_key_here
AUTH_SERVICE_URL=http://auth:3000

# OpenAI for prompt feedback (optional — empty disables feedback)
OPENAI_API_KEY=your_key_here
PROMPT_FEEDBACK_MODEL=gpt-4.1-mini

# Comma-separated allowed origins for CORS (defaults to http://localhost:5173 if unset)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Set to 1 in dev to skip the CLIP warmup thread on startup (faster --reload)
CLIP_SKIP_WARMUP=0
