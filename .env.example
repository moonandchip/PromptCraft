# Frontend
VITE_API_URL=http://localhost:8000
VITE_AUTH_URL=http://localhost:3000

# Backend — Database (auto-normalized postgres:// → postgresql+psycopg://)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptcraft?schema=public

# Backend — External services
LEONARDO_API_KEY=your_key_here
AUTH_SERVICE_URL=http://localhost:3000

# Backend — OpenAI for prompt feedback (optional)
OPENAI_API_KEY=your_key_here
PROMPT_FEEDBACK_MODEL=gpt-4.1-mini

# Backend — Comma-separated allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Backend — Skip CLIP warmup at startup (1 in dev for faster --reload)
CLIP_SKIP_WARMUP=0

# Auth service
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptcraft?schema=auth
AUTH_SECRET=replace-with-long-random-string
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
